{% raw %}
<style>:root{--brand:#1B2A4A;--brand-70:#122038;--brand-5:#EEF1F6;--brand-10:#DCE2EC;--brand-20:#C2CBDD;--g90:#0F172A;--g80:#1E293B;--g70:#334155;--g60:#475569;--g50:#64748B;--g40:#94A3B8;--g30:#CBD5E1;--g20:#E2E8F0;--g10:#F1F5F9;--g5:#F8FAFC;--succ:#16A34A;--succ-10:#DCFCE7;--warn-60:#D97706;--warn-10:#FEF3C7;--red:#E24B4A;--red-10:#FEE2E2;--purple-10:#F3E8FF;}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;background:var(--g5);color:var(--g90);font-size:14px;-webkit-font-smoothing:antialiased;}
a{text-decoration:none;color:inherit;}
.wrap{max-width:1440px;margin:0 auto;}
.hdr{background:#fff;border-bottom:1px solid var(--g10);position:sticky;top:0;z-index:100;}
.hdr-in{display:flex;align-items:center;justify-content:space-between;padding:16px 80px;}
.hdr-left{display:flex;gap:40px;align-items:center;}
.logo{display:flex;gap:10px;align-items:center;}
.logo .mark{width:32px;height:32px;background:var(--brand);border-radius:8px;}
.logo .name{font-weight:800;font-size:20px;}
.nav{display:flex;gap:28px;}
.nav a{font-weight:500;font-size:14px;color:var(--g60);}
.nav a:hover,.nav a.on{color:var(--brand);}
.hdr-right{display:flex;gap:16px;align-items:center;}
.lang{font-weight:600;font-size:13px;color:var(--g80);}
.hbtn{font-weight:600;font-size:13px;padding:10px 16px;border-radius:8px;cursor:pointer;}
.hbtn.ghost{background:var(--g5);border:1px solid var(--g20);}
.hbtn.primary{background:var(--brand);color:#fff;}
.ft{background:#fff;border-top:1px solid var(--g10);padding:48px 80px 32px;margin-top:48px;}
.ft-cols{display:flex;justify-content:space-between;max-width:1280px;margin:0 auto;}
.ft-col{display:flex;flex-direction:column;gap:12px;}
.ft-col .t{font-weight:700;font-size:13px;color:var(--g80);}
.ft-col a{font-size:12px;color:var(--g60);}
.ft-col a:hover{color:var(--brand);}
.ft-line{height:1px;background:var(--g10);margin:32px auto 20px;max-width:1280px;}
.ft-cp{font-size:12px;color:var(--g50);max-width:1280px;margin:0 auto;}
.content{padding:24px 80px 0;}
.crumbs{display:flex;gap:8px;font-size:13px;color:var(--g50);margin-bottom:20px;}
.zk-hero{display:flex;gap:24px;align-items:flex-start;}
.zk-gallery{flex:1;min-width:0;}
.zk-main-img{height:440px;border-radius:16px;background:linear-gradient(135deg,#dbe4fb,#a5b8f0);position:relative;overflow:hidden;}
.zk-tags{position:absolute;top:16px;left:16px;display:flex;gap:8px;}
.zk-tag{font-size:12px;font-weight:600;padding:5px 12px;border-radius:20px;}
.zk-3d{position:absolute;bottom:16px;left:16px;background:rgba(15,23,42,.75);color:#fff;font-size:13px;font-weight:600;padding:8px 16px;border-radius:10px;cursor:pointer;}
.zk-photos{position:absolute;bottom:16px;right:16px;background:rgba(15,23,42,.75);color:#fff;font-size:12px;padding:6px 12px;border-radius:8px;}
.zk-mediatabs{display:flex;gap:8px;margin-top:14px;flex-wrap:wrap;}
.zk-mtab{padding:9px 16px;border:1px solid var(--g20);border-radius:8px;font-size:13px;font-weight:600;color:var(--g60);cursor:pointer;background:#fff;}
.zk-mtab.on{background:var(--g90);color:#fff;border-color:var(--g90);}
.zk-side{width:380px;flex-shrink:0;background:#fff;border:1px solid var(--g20);border-radius:16px;padding:24px;position:sticky;top:100px;}
.zk-name{font-size:24px;font-weight:800;}
.zk-addr{font-size:13px;color:var(--g60);margin-top:8px;line-height:1.5;}
.zk-metrics{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:20px;}
.zk-metric{background:var(--g5);border-radius:12px;padding:14px;}
.zk-metric b{font-size:17px;font-weight:800;color:var(--g90);display:block;}
.zk-metric span{font-size:12px;color:var(--g50);margin-top:2px;display:block;}
.zk-dev-row{display:flex;align-items:center;gap:12px;margin-top:16px;padding-top:16px;border-top:1px solid var(--g10);}
.zk-dev-logo{width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,var(--brand),#3A5488);}
.zk-dev-info b{font-size:14px;font-weight:600;display:block;}
.zk-dev-info span{font-size:12px;color:var(--g50);}
.zk-btn{width:100%;margin-top:16px;background:var(--brand);color:#fff;border:none;border-radius:10px;padding:14px;font-family:inherit;font-weight:600;font-size:15px;cursor:pointer;}
.zk-btn2{width:100%;margin-top:10px;background:var(--g5);border:1px solid var(--g20);border-radius:10px;padding:12px;font-family:inherit;font-weight:600;font-size:14px;color:var(--g70);cursor:pointer;}
.zk-nav{display:flex;gap:0;border-bottom:1px solid var(--g10);margin-top:32px;overflow-x:auto;position:sticky;top:73px;background:var(--g5);z-index:50;}
.zk-nav a{padding:16px 18px;font-size:14px;font-weight:500;color:var(--g60);white-space:nowrap;border-bottom:2px solid transparent;}
.zk-nav a.on{color:var(--brand);border-bottom-color:var(--brand);}
.sec{background:#fff;border:1px solid var(--g20);border-radius:16px;padding:28px;margin-top:24px;}
.sec h2{font-size:22px;font-weight:700;margin-bottom:20px;}
.korpus-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
.korpus{border:1.5px solid var(--g20);border-radius:12px;padding:20px;cursor:pointer;}
.korpus.on{border-color:var(--brand);background:var(--brand-5);}
.korpus .status{font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;display:inline-block;margin-bottom:10px;}
.korpus b{font-size:17px;font-weight:700;display:block;}
.korpus span{font-size:13px;color:var(--g50);margin-top:4px;display:block;}
.chess-legend{display:flex;gap:20px;margin-bottom:20px;}
.cl{display:flex;gap:8px;align-items:center;font-size:13px;color:var(--g60);}
.cl .box{width:16px;height:16px;border-radius:4px;}
.chess{display:grid;grid-template-columns:60px repeat(5,1fr);gap:6px;}
.chess .flr{display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:var(--g50);}
.apt{border-radius:8px;padding:10px;text-align:center;cursor:pointer;transition:all .1s;}
.apt:hover{transform:scale(1.05);}
.apt.free{background:var(--succ-10);}
.apt.bron{background:var(--warn-10);}
.apt.sold{background:var(--g10);color:var(--g40);}
.apt .t{font-size:12px;font-weight:600;color:var(--g80);}
.apt.sold .t{color:var(--g40);}
.apt .p{font-size:11px;color:var(--g60);margin-top:3px;}
.staff-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
.staff{border:1px solid var(--g20);border-radius:14px;padding:18px;text-align:center;position:relative;}
.staff .pro{position:absolute;top:12px;right:12px;background:var(--warn-10);color:var(--warn-60);font-size:10px;font-weight:700;padding:3px 8px;border-radius:20px;}
.staff-av{width:60px;height:60px;border-radius:50%;margin:0 auto 12px;background:linear-gradient(135deg,var(--brand),#3A5488);}
.staff b{font-size:14px;font-weight:700;display:block;}
.staff .ag{font-size:12px;color:var(--brand);margin-top:2px;}
.staff .rt{font-size:12px;color:var(--warn-60);font-weight:600;margin-top:8px;}
.staff .meta{font-size:11px;color:var(--g50);margin-top:2px;}
.staff button{width:100%;margin-top:12px;background:var(--g5);border:1px solid var(--g20);border-radius:8px;padding:8px;font-family:inherit;font-weight:600;font-size:12px;color:var(--g70);cursor:pointer;}
@media(max-width:1100px){.zk-hero{flex-direction:column;}.zk-side{width:100%;position:static;}.staff-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:900px){.hdr-in,.content,.ft{padding-left:24px;padding-right:24px;}.nav{display:none;}.zk-main-img{height:280px;}.korpus-grid{grid-template-columns:1fr;}.chess{grid-template-columns:40px repeat(5,1fr);}.staff-grid{grid-template-columns:1fr;}.ft-cols{flex-wrap:wrap;gap:24px;}}
