---
{% raw %}
<style>:root{--brand:#1B2A4A;--brand-70:#122038;--brand-5:#EEF1F6;--brand-10:#DCE2EC;--brand-20:#C2CBDD;--g90:#0F172A;--g80:#1E293B;--g70:#334155;--g60:#475569;--g50:#64748B;--g40:#94A3B8;--g30:#CBD5E1;--g20:#E2E8F0;--g10:#F1F5F9;--g5:#F8FAFC;--succ:#16A34A;--succ-10:#DCFCE7;--warn-60:#D97706;--warn-10:#FEF3C7;--red:#E24B4A;--red-10:#FEE2E2;--purple-10:#F3E8FF;}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;background:var(--g5);color:var(--g90);font-size:14px;-webkit-font-smoothing:antialiased;}
a{text-decoration:none;color:inherit;}
.wrap{max-width:1440px;margin:0 auto;}
.hdr{background:#fff;border-bottom:1px solid var(--g10);position:sticky;top:0;z-index:100;}
.hdr-in{display:flex;align-items:center;justify-content:space-between;padding:16px 80px;}
.hdr-left{display:flex;gap:40px;align-items:center;}
.logo{display:flex;gap:10px;align-items:center;}
.logo .mark{width:32px;height:32px;background:var(--brand);border-radius:8px;}
.logo .name{font-weight:800;font-size:20px;}
.nav{display:flex;gap:28px;}
.nav a{font-weight:500;font-size:14px;color:var(--g60);}
.nav a:hover,.nav a.on{color:var(--brand);}
.hdr-right{display:flex;gap:16px;align-items:center;}
.lang{font-weight:600;font-size:13px;color:var(--g80);}
.hbtn{font-weight:600;font-size:13px;padding:10px 16px;border-radius:8px;cursor:pointer;}
.hbtn.ghost{background:var(--g5);border:1px solid var(--g20);}
.hbtn.primary{background:var(--brand);color:#fff;}
.ft{background:#fff;border-top:1px solid var(--g10);padding:48px 80px 32px;margin-top:48px;}
.ft-cols{display:flex;justify-content:space-between;max-width:1280px;margin:0 auto;}
.ft-col{display:flex;flex-direction:column;gap:12px;}
.ft-col .t{font-weight:700;font-size:13px;color:var(--g80);}
.ft-col a{font-size:12px;color:var(--g60);}
.ft-col a:hover{color:var(--brand);}
.ft-line{height:1px;background:var(--g10);margin:32px auto 20px;max-width:1280px;}
.ft-cp{font-size:12px;color:var(--g50);max-width:1280px;margin:0 auto;}
.cover{height:220px;background:linear-gradient(135deg,#1e293b,#334155);position:relative;}
.content{padding:0 80px;max-width:1200px;margin:0 auto;}
.dhead{background:#fff;border:1px solid var(--g20);border-radius:20px;padding:28px;margin-top:-80px;position:relative;display:flex;gap:24px;flex-wrap:wrap;}
.dhead-logo{width:100px;height:100px;border-radius:20px;background:var(--g90);display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:800;color:#fff;flex-shrink:0;letter-spacing:1px;}
.dhead-info{flex:1;min-width:280px;}
.dhead-badges{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px;}
.dbadge{font-size:11px;font-weight:600;padding:4px 10px;border-radius:20px;}
.dhead-info h1{font-size:28px;font-weight:800;}
.dhead-info p{font-size:14px;color:var(--g60);margin-top:8px;max-width:560px;line-height:1.5;}
.dhead-stats{display:flex;gap:28px;margin-top:18px;flex-wrap:wrap;}
.dstat b{font-size:20px;font-weight:800;color:var(--g90);display:block;}
.dstat span{font-size:12px;color:var(--g50);}
.dhead-btns{display:flex;flex-direction:column;gap:10px;}
.dhead-btns .b1{background:var(--brand);color:#fff;border:none;border-radius:10px;padding:12px 24px;font-family:inherit;font-weight:600;font-size:14px;cursor:pointer;white-space:nowrap;}
.dhead-btns .b2{background:#fff;border:1px solid var(--g20);border-radius:10px;padding:12px 24px;font-family:inherit;font-weight:600;font-size:14px;color:var(--g70);cursor:pointer;white-space:nowrap;}
.dtabs{display:flex;gap:0;border-bottom:1px solid var(--g10);margin-top:28px;overflow-x:auto;}
.dtab{padding:16px 20px;font-size:14px;font-weight:500;color:var(--g60);white-space:nowrap;border-bottom:2px solid transparent;cursor:pointer;}
.dtab.on{color:var(--brand);border-bottom-color:var(--brand);}
.zk-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin:32px 0 40px;}
.zk{background:#fff;border:1px solid var(--g20);border-radius:16px;overflow:hidden;cursor:pointer;transition:all .15s;}
.zk:hover{box-shadow:0 8px 20px rgba(0,0,0,.08);transform:translateY(-3px);}
.zk-img{height:180px;position:relative;}
.zk-status{position:absolute;top:14px;left:14px;font-size:11px;font-weight:600;padding:5px 12px;border-radius:20px;}
.zk-disc{position:absolute;top:14px;right:14px;background:var(--red-10);color:var(--red);font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;}
.zk-body{padding:18px;}
.zk-body b{font-size:17px;font-weight:700;display:block;}
.zk-body .info{font-size:13px;color:var(--g50);margin-top:8px;}
.zk-body .price{font-size:16px;font-weight:800;color:var(--g90);margin-top:12px;}
.zk-body .open{font-size:13px;font-weight:600;color:var(--brand);margin-top:10px;display:inline-block;}
@media(max-width:1100px){.zk-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:900px){.hdr-in,.content,.ft{padding-left:24px;padding-right:24px;}.nav{display:none;}.zk-grid{grid-template-columns:1fr;}.dhead-info h1{font-size:22px;}.ft-cols{flex-wrap:wrap;gap:24px;}}
/* ===== REFAR BRAND ===== */
.logo{display:flex;gap:10px;align-items:center;}
.logo .logo-mark{width:36px;height:36px;flex-shrink:0;display:block;}
.logo .logo-mark svg{width:100%;height:100%;display:block;}
.logo .logo-name{font-weight:800;font-size:20px;color:#1B2A4A;letter-spacing:.5px;line-height:1;}
.ft-logo{display:flex;gap:10px;align-items:center;}
.ft-logo .logo-mark{width:36px;height:36px;flex-shrink:0;display:block;}
.ft-logo .logo-mark svg{width:100%;height:100%;display:block;}
.ft-logo .logo-name{font-weight:800;font-size:22px;color:#1B2A4A;letter-spacing:.5px;}
a.hbtn.primary,a.hlink.primary,.hbtn.primary,.hlink.primary{background:#E24B4A!important;color:#fff!important;border-color:#E24B4A!important;text-decoration:none;display:inline-flex;align-items:center;}
a.hbtn.primary:hover,.hbtn.primary:hover,.hlink.primary:hover{background:#C63D3C!important;}
a.hbtn,a.hlink{text-decoration:none;}
</style>
