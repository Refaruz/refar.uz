  var xs=[80,260,440,620], ys=[80,180,280];
  ys.forEach(function(y){xs.forEach(function(x){
    var m=document.createElement("span");m.className="mk";m.style.left=x+"px";m.style.top=y+"px";map.appendChild(m);
