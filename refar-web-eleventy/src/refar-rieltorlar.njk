---
layout: base.njk
title: "Риэлторы Узбекистана · REFAR"
activeNav: "rieltorlar"
permalink: "/refar-rieltorlar.html"
---
{% raw %}
<style>
:root{--brand:#1B2A4A;--brand-70:#122038;--brand-5:#EEF1F6;--brand-10:#DCE2EC;--brand-20:#C2CBDD;--g90:#0F172A;--g80:#1E293B;--g70:#334155;--g60:#475569;--g50:#64748B;--g40:#94A3B8;--g30:#CBD5E1;--g20:#E2E8F0;--g10:#F1F5F9;--g5:#F8FAFC;--succ:#16A34A;--succ-10:#DCFCE7;--warn-60:#D97706;--warn-10:#FEF3C7;}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;background:var(--g5);color:var(--g90);font-size:14px;-webkit-font-smoothing:antialiased;}
a{text-decoration:none;color:inherit;}
.wrap{max-width:1440px;margin:0 auto;}
.hdr{background:#fff;border-bottom:1px solid var(--g10);position:sticky;top:0;z-index:100;}
.hdr-in{display:flex;align-items:center;justify-content:space-between;padding:16px 80px;}
.hdr-left{display:flex;gap:40px;align-items:center;}
.logo{display:flex;gap:10px;align-items:center;}
.logo .mark{width:32px;height:32px;background:var(--brand);border-radius:8px;}
.logo .name{font-weight:800;font-size:20px;}
.nav{display:flex;gap:28px;}
.nav a{font-weight:500;font-size:14px;color:var(--g60);}
.nav a:hover,.nav a.on{color:var(--brand);}
.hdr-right{display:flex;gap:16px;align-items:center;}
.hbtn{font-weight:600;font-size:13px;padding:10px 16px;border-radius:8px;cursor:pointer;}
.hbtn.ghost{background:var(--g5);border:1px solid var(--g20);}
.hbtn.primary{background:var(--brand);color:#fff;}
.content{padding:40px 80px 0;}
.hero h1{font-size:36px;font-weight:800;color:var(--g90);}
.hero p{font-size:15px;color:var(--g60);margin-top:12px;}
.searchbar{margin-top:28px;background:#fff;border:1px solid var(--g20);border-radius:14px;padding:16px;display:flex;gap:12px;align-items:center;flex-wrap:wrap;}
.searchbar .search{flex:1;min-width:280px;background:var(--g5);border:1px solid var(--g20);border-radius:10px;padding:12px 16px;font-size:14px;color:var(--g40);display:flex;gap:10px;align-items:center;}
.sfp{display:flex;flex-direction:column;gap:2px;padding:0 16px;border-left:1px solid var(--g20);}
.sfp .l{font-size:11px;color:var(--g40);}
.sfp .v{font-size:14px;font-weight:600;color:var(--g80);}
.tabs{display:flex;gap:8px;margin-top:24px;flex-wrap:wrap;}
.tab{border:1px solid var(--g20);border-radius:20px;padding:9px 18px;font-size:14px;color:var(--g70);cursor:pointer;background:#fff;}
.tab.on{background:var(--brand);color:#fff;border-color:var(--brand);}
.rgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-top:28px;}
.rcard{background:#fff;border:1px solid var(--g20);border-radius:16px;padding:24px;text-align:center;cursor:pointer;transition:all .15s;position:relative;}
.rcard:hover{box-shadow:0 10px 28px rgba(0,0,0,.08);transform:translateY(-3px);}
.rpro{position:absolute;top:16px;right:16px;background:var(--warn-10);color:var(--warn-60);font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;}
.ravatar{width:80px;height:80px;border-radius:50%;margin:0 auto 16px;background:linear-gradient(135deg,var(--brand),#3A5488);position:relative;}
.ravatar .on-dot{position:absolute;bottom:4px;right:4px;width:16px;height:16px;background:var(--succ);border:3px solid #fff;border-radius:50%;}
.rname{font-size:17px;font-weight:700;color:var(--g90);}
.ragency{font-size:13px;color:var(--brand);margin-top:4px;}
.rrating{display:flex;align-items:center;justify-content:center;gap:6px;margin-top:12px;}
.rrating .star{color:var(--warn-60);font-weight:700;font-size:15px;}
.rstats{display:flex;justify-content:center;gap:20px;margin-top:14px;padding-top:14px;border-top:1px solid var(--g10);}
.rstat b{font-size:16px;font-weight:700;color:var(--g90);display:block;}
.rstat span{font-size:11px;color:var(--g50);}
.rspec{display:inline-block;background:var(--brand-5);color:var(--brand-70);border-radius:20px;padding:6px 14px;font-size:12px;font-weight:600;margin-top:14px;}
.rbtn{width:100%;margin-top:16px;background:var(--g5);border:1px solid var(--g20);border-radius:10px;padding:11px;font-family:inherit;font-weight:600;font-size:13px;color:var(--g70);cursor:pointer;}
.rbtn:hover{background:var(--brand);color:#fff;border-color:var(--brand);}
.more{text-align:center;margin:40px 0;}
.more button{background:#fff;border:1px solid var(--brand);color:var(--brand);border-radius:10px;padding:14px 40px;font-family:inherit;font-weight:600;font-size:14px;cursor:pointer;}
.ft{background:#fff;border-top:1px solid var(--g10);padding:48px 80px 32px;margin-top:20px;}
.ft-cols{display:flex;justify-content:space-between;}
.ft-col{display:flex;flex-direction:column;gap:12px;}
.ft-col .t{font-weight:700;font-size:13px;color:var(--g80);}
.ft-col a{font-size:12px;color:var(--g60);}
.ft-col a:hover{color:var(--brand);}
.ft-line{height:1px;background:var(--g10);margin:32px 0 20px;}
.ft-cp{font-size:12px;color:var(--g50);}
@media(max-width:1200px){.rgrid{grid-template-columns:repeat(3,1fr);}}
@media(max-width:900px){.hdr-in,.content,.ft{padding-left:24px;padding-right:24px;}.nav{display:none;}.rgrid{grid-template-columns:repeat(2,1fr);}.hero h1{font-size:28px;}}
@media(max-width:600px){.rgrid{grid-template-columns:1fr;}.ft-cols{flex-wrap:wrap;gap:24px;}}

/* ===== REFAR BRAND ===== */
.logo{display:flex;gap:10px;align-items:center;}
.logo .logo-mark{width:36px;height:36px;flex-shrink:0;display:block;}
.logo .logo-mark svg{width:100%;height:100%;display:block;}
.logo .logo-name{font-weight:800;font-size:20px;color:#1B2A4A;letter-spacing:.5px;line-height:1;}
.ft-logo{display:flex;gap:10px;align-items:center;}
.ft-logo .logo-mark{width:36px;height:36px;flex-shrink:0;display:block;}
.ft-logo .logo-mark svg{width:100%;height:100%;display:block;}
.ft-logo .logo-name{font-weight:800;font-size:22px;color:#1B2A4A;letter-spacing:.5px;}
a.hbtn.primary,a.hlink.primary,.hbtn.primary,.hlink.primary{background:#E24B4A!important;color:#fff!important;border-color:#E24B4A!important;text-decoration:none;display:inline-flex;align-items:center;}
a.hbtn.primary:hover,.hbtn.primary:hover,.hlink.primary:hover{background:#C63D3C!important;}
a.hbtn,a.hlink{text-decoration:none;}
</style>
<div class="content">
  <div class="hero"><h1>Риэлторы Узбекистана</h1><p>842 проверенных агента. Все с подтверждёнными лицензиями и историей сделок.</p></div>

  <div class="searchbar">
    <div class="search">🔍 Поиск по имени, агентству или специализации</div>
    <div class="sfp"><span class="l">Город</span><span class="v">Ташкент ▾</span></div>
    <div class="sfp"><span class="l">Район</span><span class="v">Все ▾</span></div>
    <div class="sfp"><span class="l">Рейтинг</span><span class="v">от 4.5★ ▾</span></div>
    <div class="sfp"><span class="l">Специализация</span><span class="v">Все ▾</span></div>
  </div>

  <div class="tabs"><span class="tab on">Все агенты</span><span class="tab">Премиум</span><span class="tab">Online сейчас</span><span class="tab">Новые</span></div>

  <div class="rgrid" id="rgrid"></div>
  <div class="more"><button>Показать ещё агентов</button></div>
</div>
</div>
<script>
var agents=[
  {pro:1,online:1,name:'Светлана Михайлова',agency:'Tashkent Realty',rating:'4.9',deals:'47',exp:'5 лет',spec:'Премиум-сегмент',av:'linear-gradient(135deg,#1B2A4A,#3A5488)'},
  {pro:0,online:0,name:'Дмитрий Чен',agency:'Орзу Estate',rating:'4.7',deals:'32',exp:'3 года',spec:'Новостройки',av:'linear-gradient(135deg,#16A34A,#4ADE80)'},
  {pro:0,online:1,name:'Анна Гарсия',agency:'REFAR Plus',rating:'4.8',deals:'28',exp:'4 года',spec:'Аренда',av:'linear-gradient(135deg,#D97706,#FBBF24)'},
  {pro:1,online:0,name:'Бекзод Назаров',agency:'Tashkent Realty',rating:'4.9',deals:'64',exp:'7 лет',spec:'Коммерческая',av:'linear-gradient(135deg,#7C3AED,#A78BFA)'},
  {pro:0,online:1,name:'Камилла Абдуллаева',agency:'Орзу Estate',rating:'4.6',deals:'21',exp:'2 года',spec:'Семейное жильё',av:'linear-gradient(135deg,#DB2777,#F472B6)'},
  {pro:0,online:0,name:'Алишер Каримов',agency:'Independent',rating:'4.8',deals:'39',exp:'6 лет',spec:'Премиум-сегмент',av:'linear-gradient(135deg,#0891B2,#22D3EE)'},
  {pro:1,online:1,name:'Дилшод Юлдашев',agency:'REFAR Plus',rating:'4.7',deals:'25',exp:'3 года',spec:'Новостройки',av:'linear-gradient(135deg,#1B2A4A,#3A5488)'},
  {pro:0,online:0,name:'Нигора Рахимова',agency:'Tashkent Realty',rating:'4.8',deals:'42',exp:'5 лет',spec:'Аренда',av:'linear-gradient(135deg,#16A34A,#4ADE80)'}
];
document.getElementById("rgrid").innerHTML=agents.map(function(a){
  return '<div class="rcard" onclick="location.href=&#39;refar-agency-profile.html&#39;" style="cursor:pointer">'+(a.pro?'<span class="rpro">PRO</span>':'')+
    '<div class="ravatar" style="background:'+a.av+'">'+(a.online?'<span class="on-dot"></span>':'')+'</div>'+
    '<div class="rname">'+a.name+'</div><div class="ragency">'+a.agency+'</div>'+
    '<div class="rrating"><span class="star">★ '+a.rating+'</span></div>'+
    '<div class="rstats"><div class="rstat"><b>'+a.deals+'</b><span>сделок</span></div><div class="rstat"><b>'+a.exp+'</b><span>опыт</span></div></div>'+
    '<div class="rspec">'+a.spec+'</div>'+
    '<button class="rbtn">Профиль</button></div>';
}).join("");
document.querySelectorAll(".tab").forEach(function(t){t.addEventListener("click",function(){document.querySelectorAll(".tab").forEach(function(x){x.classList.remove("on");});t.classList.add("on");});});
</script>
{% endraw %}
