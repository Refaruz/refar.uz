// Supabase'dan haqiqiy tasdiqlangan e'lonlarni yuklash (demo bilan aralash)
async function loadRealListings(){
  if(!window.sb) return;
  try{
    var {data}=await window.sb.from('web_listings').select('*').eq('status','approved').order('created_at',{ascending:false}).limit(12);
    if(data&&data.length){
      var real=data.map(function(l){
        var st=l.deal_type==='rent'?'Аренда':(l.deal_type==='daily'?'Посуточно':'В продаже');
        var img=(l.images&&l.images[0])?"url("+l.images[0]+") center/cover":'linear-gradient(135deg,#dbe4fb,#c9d6f7)';
        var pr=(l.currency==='USD'?'$ ':'')+Number(l.price).toLocaleString('ru-RU')+(l.currency==='UZS'?' сум':'')+(l.deal_type==='rent'?' /мес':'');
        return {id:l.id,ph:img,badges:[['📷 '+((l.images||[]).length||0),''],['✓ Проверено REFAR','ok']],fav:1,status:st,statusBg:'#DCFCE7;color:#16A34A',price:pr,per:[l.region,l.district].filter(Boolean).join(', '),r:(l.rooms||'-')+'',m:(l.area||'-')+'',f:(l.floor?l.floor+'/'+(l.floor_total||'-'):'-'),near:[]};
      });
      props=real.concat(props);  // haqiqiy e'lonlar birinchi
      renderGrid();
      var f=document.querySelector('.found'); if(f) f.textContent='Найдено '+props.length+' объектов';
    }
  }catch(e){console.warn('listings',e);}
}
function renderGrid(){
document.getElementById("grid").innerHTML=props.map(function(p){
  return '<div class="pcard" onclick="location.href=&#39;refar-object.html'+(p.id?'?id='+p.id:'')+'&#39;"><div class="pcard-hero" style="background:'+p.ph+'">'+
    '<div class="pcard-badges">'+p.badges.map(function(b){return '<span class="pbadge '+b[1]+'">'+b[0]+'</span>';}).join("")+
    '<div class="pcard-fav"><span>♥</span><span>⇄</span></div></div>'+
    '<div class="pcard-info"><span class="status" style="background:'+p.statusBg+'">'+p.status+'</span><div class="price">'+p.price+'</div><div class="permet">'+p.per+'</div></div></div>'+
    '<div class="pcard-body"><div class="pcard-specs">'+
    '<div class="pspec"><b>'+p.r+'</b><span>комн.</span></div>'+
    '<div class="pspec"><b>'+p.m+'</b><span>'+(p.f.indexOf("сот")>-1?"":"м²")+'</span></div>'+
    '<div class="pspec"><b>'+p.f+'</b><span>'+(p.f.indexOf("сот")>-1?"участок":"этаж")+'</span></div></div>'+
    '<div class="pcard-near"><div class="nt">ПОБЛИЗОСТИ</div>'+
    p.near.map(function(n){return '<div class="pnear"><span class="ic">'+n[0]+'</span><span class="nm">'+n[1]+'</span><span class="line"></span><span class="dist">'+n[2]+'</span></div>';}).join("")+
    '</div></div></div>';
}).join("");
}
renderGrid();
document.addEventListener('DOMContentLoaded',loadRealListings);
// Interaktiv
document.querySelectorAll(".fcb,.fchip,.qcat").forEach(function(e){e.addEventListener("click",function(){
  if(e.classList.contains("fchip")&&e.parentNode.querySelector(".fchip.on")&&!e.parentNode.classList.contains("fchips-multi")){}
  e.classList.toggle("on");
});});
</script>
