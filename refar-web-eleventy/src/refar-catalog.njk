---
layout: base.njk
title: "Каталог недвижимости · REFAR"
activeNav: "catalog"
permalink: "/refar-catalog.html"
---
{% raw %}
<style>
:root{
  --brand:#1B2A4A; --brand-70:#122038; --brand-5:#EEF1F6; --brand-10:#DCE2EC; --brand-20:#C2CBDD;
  --g90:#0F172A; --g80:#1E293B; --g70:#334155; --g60:#475569; --g50:#64748B; --g40:#94A3B8;
  --g30:#CBD5E1; --g20:#E2E8F0; --g10:#F1F5F9; --g5:#F8FAFC; --white:#FFFFFF;
  --succ:#16A34A; --succ-10:#DCFCE7; --warn-10:#FEF3C7; --warn-60:#D97706; --purple-10:#F3E8FF;
  --red:#E24B4A; --red-10:#FEE2E2;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;background:var(--g5);color:var(--g90);-webkit-font-smoothing:antialiased;font-size:14px;}
a{text-decoration:none;color:inherit;}
.wrap{max-width:1760px;margin:0 auto;}

/* HEADER */
.hdr{background:#fff;border-bottom:1px solid var(--g10);position:sticky;top:0;z-index:100;}
.hdr-in{display:flex;align-items:center;gap:32px;padding:26px 80px;max-width:1920px;margin:0 auto;}
.logo{display:flex;gap:8px;align-items:baseline;}
.logo .n{font-weight:800;font-size:24px;color:var(--g90);}
.logo .s{font-weight:600;font-size:15px;color:var(--brand);}
.nav{display:flex;gap:24px;}
.nav a{font-weight:500;font-size:15px;color:var(--g60);}
.nav a:hover,.nav a.on{color:var(--brand);}
.hdr-search{margin-left:auto;width:300px;background:var(--g5);border:1px solid var(--g20);border-radius:10px;padding:11px 16px;font-size:14px;color:var(--g40);display:flex;align-items:center;gap:8px;}
.hbtn{font-weight:600;font-size:14px;padding:10px 18px;border-radius:8px;cursor:pointer;}
.hbtn.ghost{background:var(--g5);border:1px solid var(--g20);color:var(--g80);}
.hbtn.primary{background:var(--brand);color:#fff;}

/* CONTENT */
.content{padding:24px 80px 0;max-width:1920px;margin:0 auto;}
.crumbs{display:flex;gap:8px;font-size:14px;color:var(--g50);margin-bottom:24px;}
.crumbs a:hover{color:var(--brand);}
.page-title h1{font-size:36px;font-weight:800;color:var(--g90);}
.page-title p{font-size:16px;color:var(--g60);margin-top:12px;max-width:770px;}

/* AI SEARCH */
.ai-box{background:linear-gradient(135deg,#EDF0F6,#F2F1F7);border:1px solid var(--brand-20);border-radius:20px;padding:28px;margin-top:28px;}
.ai-head{display:flex;gap:16px;align-items:center;margin-bottom:20px;}
.ai-ic{width:44px;height:44px;background:var(--brand);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;color:#fff;}
.ai-head h3{font-size:22px;font-weight:700;color:var(--g90);display:flex;gap:10px;align-items:center;}
.ai-head h3 .beta{background:var(--brand);color:#fff;font-size:11px;font-weight:600;padding:2px 8px;border-radius:20px;}
.ai-head p{font-size:14px;color:var(--g60);margin-top:4px;}
.ai-row{display:flex;gap:12px;}
.ai-input{flex:1;background:#fff;border:1px solid var(--g20);border-radius:12px;padding:14px 18px;font-size:15px;color:var(--g40);display:flex;align-items:center;gap:10px;}
.ai-btn{background:var(--brand);color:#fff;border:none;border-radius:12px;padding:0 28px;font-family:inherit;font-weight:600;font-size:15px;cursor:pointer;}
.ai-chips{display:flex;gap:10px;align-items:center;margin-top:16px;flex-wrap:wrap;}
.ai-chips .lbl{font-size:14px;color:var(--g50);font-weight:500;}
.ai-chip{background:#fff;border:1px solid var(--brand-20);border-radius:20px;padding:7px 14px;font-size:13px;color:var(--brand-70);cursor:pointer;}
.ai-chip:hover{background:var(--brand-5);}

/* QUICK CATEGORIES */
.qcats{display:flex;gap:10px;flex-wrap:wrap;margin-top:28px;}
.qcat{background:#fff;border:1px solid var(--g20);border-radius:20px;padding:9px 16px;font-size:14px;color:var(--g70);cursor:pointer;}
.qcat:hover,.qcat.on{background:var(--brand);color:#fff;border-color:var(--brand);}

/* MAIN CATALOG */
.catalog{display:flex;gap:24px;margin-top:32px;align-items:flex-start;}
.filters{width:320px;flex-shrink:0;background:#fff;border:1px solid var(--g20);border-radius:16px;padding:18px;position:sticky;top:100px;max-height:calc(100vh - 120px);overflow-y:auto;}
.fh{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.fh b{font-size:18px;font-weight:700;color:var(--g90);}
.fh .reset{font-size:14px;color:var(--brand);cursor:pointer;}
.fgroup{padding:18px 0;border-bottom:1px solid var(--g10);}
.fgroup:last-of-type{border-bottom:none;}
.fgroup .flabel{font-size:14px;font-weight:600;color:var(--g80);margin-bottom:14px;}
.fchips{display:flex;gap:8px;flex-wrap:wrap;}
.fchip{border:1px solid var(--g20);border-radius:8px;padding:8px 14px;font-size:14px;color:var(--g70);cursor:pointer;}
.fchip:hover,.fchip.on{background:var(--brand);color:#fff;border-color:var(--brand);}
.fcb{display:flex;gap:10px;align-items:center;padding:5px 0;cursor:pointer;}
.fcb .box{width:18px;height:18px;border:1.5px solid var(--g30);border-radius:5px;flex-shrink:0;}
.fcb.on .box{background:var(--brand);border-color:var(--brand);position:relative;}
.fcb.on .box::after{content:"✓";color:#fff;font-size:12px;position:absolute;left:3px;top:-1px;}
.fcb span{font-size:14px;color:var(--g70);}
.fdrop{width:100%;border:1px solid var(--g20);border-radius:8px;padding:10px 14px;font-size:14px;color:var(--g50);cursor:pointer;display:flex;justify-content:space-between;align-items:center;}
.ftags{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;}
.ftag{background:var(--brand-5);color:var(--brand-70);border-radius:6px;padding:5px 10px;font-size:12px;cursor:pointer;}
.finputs{display:flex;gap:10px;}
.finput{flex:1;border:1px solid var(--g20);border-radius:8px;padding:9px 12px;font-size:14px;color:var(--g70);}
.fbtn{width:100%;padding:12px;border-radius:8px;border:none;font-family:inherit;font-weight:600;font-size:14px;cursor:pointer;margin-top:8px;}
.fbtn.apply{background:var(--brand);color:#fff;}
.fbtn.save{background:var(--g5);border:1px solid var(--g20);color:var(--g70);}

/* RESULTS */
.results{flex:1;min-width:0;}
.sortbar{display:flex;align-items:center;gap:16px;margin-bottom:16px;}
.sortbar .found{font-size:22px;font-weight:700;color:var(--g90);flex:1;}
.sortbar .sort{border:1px solid var(--g20);border-radius:8px;padding:9px 14px;font-size:14px;color:var(--g60);background:#fff;cursor:pointer;}
.viewtabs{display:flex;gap:0;border:1px solid var(--g20);border-radius:8px;overflow:hidden;background:#fff;}
.viewtabs span{padding:9px 12px;font-size:14px;color:var(--g50);cursor:pointer;}
.viewtabs span.on{background:var(--brand);color:#fff;}
.active-f{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:16px;}
.active-f .lbl{font-size:14px;color:var(--g50);}
.af{background:var(--g10);border-radius:20px;padding:6px 12px;font-size:13px;color:var(--g70);cursor:pointer;}
.active-f .clear{font-size:14px;color:var(--brand);cursor:pointer;margin-left:8px;}
.map-banner{background:linear-gradient(135deg,#EDF0F6,#fff);border:1px solid var(--brand-20);border-radius:12px;padding:16px;display:flex;align-items:center;gap:16px;margin-bottom:24px;}
.map-banner .thumb{width:180px;height:84px;background:linear-gradient(135deg,#dbe4fb,#c9d6f7);border-radius:8px;flex-shrink:0;position:relative;}
.map-banner .thumb::after{content:"";position:absolute;left:16px;top:16px;width:60px;height:12px;background:repeating-linear-gradient(90deg,var(--brand) 0 12px,transparent 12px 24px);border-radius:6px;}
.map-banner .mtxt{flex:1;}
.map-banner .mtxt b{font-size:16px;font-weight:600;color:var(--g80);display:flex;gap:8px;align-items:center;}
.map-banner .mtxt span{font-size:14px;color:var(--g50);margin-top:4px;display:block;}
.map-banner button{background:var(--brand);color:#fff;border:none;border-radius:10px;padding:12px 20px;font-family:inherit;font-weight:600;font-size:14px;cursor:pointer;white-space:nowrap;}
.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}

/* PROPERTY CARD */
.pcard{background:#fff;border:1px solid var(--g20);border-radius:16px;overflow:hidden;cursor:pointer;transition:all .15s;}
.pcard:hover{box-shadow:0 10px 28px rgba(0,0,0,.08);transform:translateY(-3px);}
.pcard-hero{height:212px;position:relative;padding:14px;display:flex;flex-direction:column;justify-content:space-between;}
.pcard-badges{display:flex;gap:8px;}
.pbadge{background:rgba(255,255,255,.95);border-radius:8px;padding:5px 10px;font-size:12px;font-weight:500;color:var(--g70);display:flex;gap:6px;align-items:center;}
.pbadge.ok{color:var(--succ);}
.pcard-fav{margin-left:auto;display:flex;gap:8px;}
.pcard-fav span{width:36px;height:36px;background:rgba(255,255,255,.95);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;color:var(--g50);}
.pcard-info .status{display:inline-block;background:rgba(255,255,255,.95);border-radius:8px;padding:5px 10px;font-size:12px;font-weight:600;margin-bottom:8px;}
.pcard-info .price{font-size:32px;font-weight:800;color:var(--g90);}
.pcard-info .permet{font-size:13px;color:var(--g70);margin-top:6px;background:rgba(255,255,255,.9);display:inline-block;padding:3px 8px;border-radius:6px;}
.pcard-body{padding:16px;}
.pcard-specs{display:flex;border:1px solid var(--g10);border-radius:12px;overflow:hidden;margin-bottom:16px;}
.pspec{flex:1;text-align:center;padding:14px 0;border-right:1px solid var(--g10);}
.pspec:last-child{border-right:none;}
.pspec b{font-size:22px;font-weight:700;color:var(--g90);display:block;}
.pspec span{font-size:12px;color:var(--g50);}
.pcard-near .nt{font-size:11px;font-weight:600;color:var(--g40);letter-spacing:.5px;margin-bottom:12px;}
.pnear{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.pnear .ic{width:30px;height:30px;background:var(--g5);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:15px;}
.pnear .nm{font-size:14px;color:var(--g70);flex:1;}
.pnear .line{flex:1;height:1px;background:var(--g10);max-width:80px;}
.pnear .dist{font-size:13px;color:var(--g50);}

.pagination{display:flex;flex-direction:column;align-items:center;gap:20px;margin-top:32px;}
.load-more{background:#fff;border:1px solid var(--brand);color:var(--brand);border-radius:10px;padding:12px 40px;font-family:inherit;font-weight:600;font-size:14px;cursor:pointer;}
.pnums{display:flex;gap:8px;}
.pnum{width:40px;height:40px;border:1px solid var(--g20);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;color:var(--g60);cursor:pointer;background:#fff;}
.pnum.on{background:var(--brand);color:#fff;border-color:var(--brand);}

/* SOLD */
.section-block{margin-top:56px;}
.sb-head{display:flex;align-items:flex-start;margin-bottom:24px;}
.sb-head h2{font-size:28px;font-weight:700;color:var(--g90);}
.sb-head p{font-size:14px;color:var(--g50);margin-top:6px;}
.sb-head .all{margin-left:auto;font-size:14px;color:var(--brand);cursor:pointer;}
.sold-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}
.sold{background:#fff;border:1px solid var(--g20);border-radius:16px;overflow:hidden;}
.sold-photo{height:150px;background:linear-gradient(135deg,#e2e8f4,#d3dcef);position:relative;}
.sold-photo .b{position:absolute;left:12px;top:12px;background:var(--g90);color:#fff;font-size:11px;font-weight:600;padding:4px 10px;border-radius:20px;}
.sold-body{padding:16px;}
.sold-body .sp{font-size:20px;font-weight:700;color:var(--g90);}
.sold-was{display:flex;gap:10px;align-items:center;margin-top:6px;}
.sold-was .w{font-size:14px;color:var(--g40);text-decoration:line-through;}
.sold-was .d{background:var(--succ-10);color:var(--succ);font-size:11px;font-weight:600;padding:3px 8px;border-radius:20px;}
.sold-title{font-size:16px;font-weight:600;color:var(--g80);margin-top:12px;}
.sold-addr{font-size:13px;color:var(--g50);margin-top:8px;}
.sold-spec{font-size:12px;color:var(--g60);margin-top:6px;}
.sold-line{height:1px;background:var(--g10);margin:12px 0;}
.sold-date{font-size:12px;color:var(--g50);}

/* CONTACT */
.contact{display:flex;gap:24px;margin-top:56px;}
.contact-left{flex:1;background:#fff;border:1px solid var(--g20);border-radius:20px;padding:32px;}
.contact-left h2{font-size:28px;font-weight:700;color:var(--g90);}
.contact-left>p{font-size:14px;color:var(--g60);margin-top:12px;line-height:1.6;}
.cform{margin-top:24px;}
.cform textarea{width:100%;border:1px solid var(--g20);border-radius:10px;padding:14px;font-family:inherit;font-size:14px;min-height:80px;resize:vertical;}
.cform-row{display:flex;gap:10px;margin-top:12px;}
.cform-row input{flex:1;border:1px solid var(--g20);border-radius:10px;padding:12px 14px;font-family:inherit;font-size:14px;}
.cform-row button{background:var(--brand);color:#fff;border:none;border-radius:10px;padding:12px 28px;font-family:inherit;font-weight:600;font-size:14px;cursor:pointer;white-space:nowrap;}
.cform .agree{font-size:12px;color:var(--g50);margin-top:14px;}
.contact-right{width:520px;flex-shrink:0;background:#fff;border:1px solid var(--g20);border-radius:20px;padding:32px;}
.contact-right h3{font-size:19px;font-weight:700;color:var(--g90);margin-bottom:20px;}
.cstep{display:flex;gap:14px;margin-bottom:20px;}
.cstep .n{width:32px;height:32px;background:var(--brand);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;flex-shrink:0;}
.cstep .ct b{font-size:14px;font-weight:600;color:var(--g80);display:block;}
.cstep .ct span{font-size:13px;color:var(--g50);}
.cright-line{height:1px;background:var(--g10);margin:24px 0;}
.cright h4{font-size:15px;font-weight:700;color:var(--g80);margin-bottom:16px;}
.cbtns{display:flex;gap:10px;flex-wrap:wrap;}
.cbtn{border:1px solid var(--g20);border-radius:10px;padding:10px 18px;font-size:14px;font-weight:600;color:var(--g70);cursor:pointer;}
.cbtn.tg{background:var(--brand);color:#fff;border-color:var(--brand);}
.conline{font-size:13px;color:var(--g50);margin-top:16px;display:flex;gap:6px;align-items:center;}
.conline::before{content:"";width:8px;height:8px;border-radius:50%;background:var(--succ);}

/* SEO */
.seo{margin-top:56px;background:#fff;border:1px solid var(--g20);border-radius:20px;padding:32px;}
.seo h2{font-size:28px;font-weight:700;color:var(--g90);margin-bottom:24px;}
.seo-cols{display:grid;grid-template-columns:repeat(4,1fr);gap:32px;}
.seo-col .t{font-size:14px;font-weight:700;color:var(--g80);margin-bottom:16px;}
.seo-col a{display:block;font-size:14px;color:var(--g60);padding:5px 0;}
.seo-col a:hover{color:var(--brand);}

/* FOOTER */
.ft{background:#fff;border-top:1px solid var(--g10);padding:48px 80px 32px;margin-top:56px;}
.ft-in{max-width:1760px;margin:0 auto;}
.ft-top{display:flex;justify-content:space-between;gap:40px;}
.ft-brand{width:380px;}
.ft-logo{display:flex;gap:8px;align-items:baseline;margin-bottom:16px;}
.ft-logo .n{font-weight:800;font-size:24px;color:var(--g90);}
.ft-logo .s{font-weight:600;font-size:15px;color:var(--brand);}
.ft-brand p{font-size:14px;color:var(--g60);line-height:1.6;}
.ft-col .t{font-size:14px;font-weight:700;color:var(--g80);margin-bottom:16px;}
.ft-col a{display:block;font-size:14px;color:var(--g60);padding:5px 0;}
.ft-col a:hover{color:var(--brand);}
.ft-line{height:1px;background:var(--g10);margin:32px 0 24px;}
.ft-bot{display:flex;align-items:center;font-size:14px;color:var(--g50);}
.ft-soc{margin-left:auto;display:flex;gap:24px;}
.ft-soc a:hover{color:var(--brand);}

@media(max-width:1400px){
  .grid{grid-template-columns:repeat(2,1fr);}
  .sold-grid{grid-template-columns:repeat(2,1fr);}
  .seo-cols{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:1100px){
  .hdr-in,.content,.ft{padding-left:32px;padding-right:32px;}
  .nav,.hdr-search{display:none;}
  .catalog{flex-direction:column;}
  .filters{width:100%;position:static;max-height:none;}
  .contact{flex-direction:column;}
  .contact-right{width:100%;}
  .grid{grid-template-columns:1fr;}
}
@media(max-width:700px){
  .sold-grid,.seo-cols{grid-template-columns:1fr;}
  .page-title h1{font-size:28px;}
  .ai-row{flex-direction:column;}
  .ft-top{flex-wrap:wrap;gap:24px;}
}

/* ===== REFAR BRAND ===== */
.logo{display:flex;gap:10px;align-items:center;}
.logo .logo-mark{width:36px;height:36px;flex-shrink:0;display:block;}
.logo .logo-mark svg{width:100%;height:100%;display:block;}
.logo .logo-name{font-weight:800;font-size:20px;color:#1B2A4A;letter-spacing:.5px;line-height:1;}
.ft-logo{display:flex;gap:10px;align-items:center;}
.ft-logo .logo-mark{width:36px;height:36px;flex-shrink:0;display:block;}
.ft-logo .logo-mark svg{width:100%;height:100%;display:block;}
.ft-logo .logo-name{font-weight:800;font-size:22px;color:#1B2A4A;letter-spacing:.5px;}
a.hbtn.primary,a.hlink.primary,.hbtn.primary,.hlink.primary{background:#E24B4A!important;color:#fff!important;border-color:#E24B4A!important;text-decoration:none;display:inline-flex;align-items:center;}
a.hbtn.primary:hover,.hbtn.primary:hover,.hlink.primary:hover{background:#C63D3C!important;}
a.hbtn,a.hlink{text-decoration:none;}
</style>
<div class="content">
  <div class="crumbs"><a href="index.html">Главная</a><span>→</span><a href="refar-catalog.html">Каталог объектов</a></div>
  <div class="page-title">
    <h1>Каталог недвижимости</h1>
    <p>Найдите квартиру для покупки или аренды с проверенными данными, фото, видео и 360° турами.</p>
  </div>

  <!-- AI SEARCH -->
  <div class="ai-box">
    <div class="ai-head">
      <div class="ai-ic">✨</div>
      <div><h3>AI-поиск объектов <span class="beta">Beta</span></h3><p>Опишите словами, что ищете — нейросеть REFAR подберёт подходящие объекты из базы</p></div>
    </div>
    <div class="ai-row">
      <div class="ai-input">🔍 Например: «2-комнатная в Юнусабаде рядом с метро, с ремонтом, до $80 000»</div>
      <button class="ai-btn">Найти с AI</button>
    </div>
    <div class="ai-chips">
      <span class="lbl">Популярное:</span>
      <span class="ai-chip">Квартира у метро до $80k</span>
      <span class="ai-chip">Дом с участком в Кибрае</span>
      <span class="ai-chip">2-комн. с ремонтом, Юнусабад</span>
      <span class="ai-chip">Новостройка с рассрочкой</span>
    </div>
  </div>

  <!-- QUICK CATEGORIES -->
  <div class="qcats">
    <span class="qcat on">Сотувдаги квартиралар</span>
    <span class="qcat">Сотилган квартиралар</span>
    <span class="qcat">Закалат қилинган</span>
    <span class="qcat">Арзонлашган</span>
    <span class="qcat">Брон қилинган</span>
    <span class="qcat">Ижарага берилган</span>
    <span class="qcat">Ипотекага тушадиган</span>
    <span class="qcat">Янги қўшилган</span>
    <span class="qcat">100% видео</span>
    <span class="qcat">360° лойиҳали</span>
    <span class="qcat">Туманлар бўйича</span>
  </div>

  <!-- MAIN CATALOG -->
  <div class="catalog">
    <!-- FILTERS -->
    <aside class="filters">
      <div class="fh"><b>Фильтры</b><span class="reset">Сбросить</span></div>
