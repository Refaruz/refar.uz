</div><script>document.querySelectorAll(".faq-q").forEach(function(q){q.addEventListener("click",function(){q.parentNode.classList.toggle("open");});});
document.querySelectorAll(".cat").forEach(function(c){c.addEventListener("click",function(){document.querySelectorAll(".cat").forEach(function(x){x.classList.remove("on");});c.classList.add("on");});});</script>
{% endraw %}
