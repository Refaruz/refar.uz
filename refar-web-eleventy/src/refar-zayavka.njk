---
layout: base.njk
title: "Подать заявку · REFAR"
activeNav: ""
permalink: "/refar-zayavka.html"
---
{% raw %}
<style>:root{--brand:#1B2A4A;--brand-70:#122038;--brand-5:#EEF1F6;--brand-10:#DCE2EC;--brand-20:#C2CBDD;--g90:#0F172A;--g80:#1E293B;--g70:#334155;--g60:#475569;--g50:#64748B;--g40:#94A3B8;--g30:#CBD5E1;--g20:#E2E8F0;--g10:#F1F5F9;--g5:#F8FAFC;--succ:#16A34A;--succ-10:#DCFCE7;--warn-60:#D97706;--warn-10:#FEF3C7;--red:#E24B4A;--red-10:#FEE2E2;--purple-10:#F3E8FF;}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;background:var(--g5);color:var(--g90);font-size:14px;-webkit-font-smoothing:antialiased;}
a{text-decoration:none;color:inherit;}
.wrap{max-width:1440px;margin:0 auto;}
.hdr{background:#fff;border-bottom:1px solid var(--g10);position:sticky;top:0;z-index:100;}
.hdr-in{display:flex;align-items:center;justify-content:space-between;padding:16px 80px;}
.hdr-left{display:flex;gap:40px;align-items:center;}
.logo{display:flex;gap:10px;align-items:center;}
.logo .mark{width:32px;height:32px;background:var(--brand);border-radius:8px;}
.logo .name{font-weight:800;font-size:20px;}
.nav{display:flex;gap:28px;}
.nav a{font-weight:500;font-size:14px;color:var(--g60);}
.nav a:hover,.nav a.on{color:var(--brand);}
.hdr-right{display:flex;gap:16px;align-items:center;}
.lang{font-weight:600;font-size:13px;color:var(--g80);}
.hbtn{font-weight:600;font-size:13px;padding:10px 16px;border-radius:8px;cursor:pointer;}
.hbtn.ghost{background:var(--g5);border:1px solid var(--g20);}
.hbtn.primary{background:var(--brand);color:#fff;}
.ft{background:#fff;border-top:1px solid var(--g10);padding:48px 80px 32px;margin-top:48px;}
.ft-cols{display:flex;justify-content:space-between;max-width:1280px;margin:0 auto;}
.ft-col{display:flex;flex-direction:column;gap:12px;}
.ft-col .t{font-weight:700;font-size:13px;color:var(--g80);}
.ft-col a{font-size:12px;color:var(--g60);}
.ft-col a:hover{color:var(--brand);}
.ft-line{height:1px;background:var(--g10);margin:32px auto 20px;max-width:1280px;}
.ft-cp{font-size:12px;color:var(--g50);max-width:1280px;margin:0 auto;}
.content{padding:40px 80px;max-width:1000px;margin:0 auto;}
.pt{text-align:center;margin-bottom:32px;}.pt h1{font-size:34px;font-weight:800;}.pt p{font-size:15px;color:var(--g60);margin-top:12px;}
.zwrap{display:flex;gap:24px;align-items:flex-start;}
.zform{flex:1;background:#fff;border:1px solid var(--g20);border-radius:20px;padding:32px;}
.progress{display:flex;gap:8px;margin-bottom:8px;}
.pstep{flex:1;height:6px;border-radius:3px;background:var(--g20);}.pstep.done,.pstep.on{background:var(--brand);}
.pstep-label{font-size:13px;color:var(--g50);margin-bottom:24px;}
.zform h2{font-size:22px;font-weight:700;margin-bottom:24px;}
.field{margin-bottom:22px;}.field .fl{font-size:14px;font-weight:600;color:var(--g70);margin-bottom:10px;}
.chips{display:flex;gap:10px;flex-wrap:wrap;}
.chip{border:1.5px solid var(--g20);border-radius:10px;padding:10px 18px;font-size:14px;font-weight:600;color:var(--g70);cursor:pointer;}
.chip.on{border-color:var(--brand);background:var(--brand-5);color:var(--brand-70);}
.frow{display:flex;gap:16px;}.frow .field{flex:1;}
.finput{width:100%;border:1px solid var(--g20);border-radius:10px;padding:12px 14px;font-family:inherit;font-size:14px;color:var(--g80);}
.fselect{width:100%;border:1px solid var(--g20);border-radius:10px;padding:12px 14px;font-size:14px;color:var(--g80);cursor:pointer;display:flex;justify-content:space-between;}
.rooms{display:flex;gap:10px;flex-wrap:wrap;}
.room{min-width:52px;height:44px;padding:0 14px;border:1.5px solid var(--g20);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;color:var(--g70);cursor:pointer;}
.room.on{border-color:var(--brand);background:var(--brand-5);color:var(--brand-70);}
.form-btns{display:flex;justify-content:space-between;margin-top:12px;}
.btn-back{background:var(--g5);border:1px solid var(--g20);border-radius:10px;padding:13px 24px;font-family:inherit;font-weight:600;font-size:14px;color:var(--g70);cursor:pointer;}
.btn-next{background:var(--brand);color:#fff;border:none;border-radius:10px;padding:13px 32px;font-family:inherit;font-weight:600;font-size:14px;cursor:pointer;}
.zside{width:340px;flex-shrink:0;background:#fff;border:1px solid var(--g20);border-radius:20px;padding:28px;position:sticky;top:100px;}
.zside h3{font-size:18px;font-weight:700;margin-bottom:20px;}
.zstep{display:flex;gap:14px;margin-bottom:18px;}
.zstep .n{width:28px;height:28px;background:var(--brand-5);color:var(--brand-70);border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:13px;flex-shrink:0;}
.zstep .t{font-size:14px;color:var(--g70);padding-top:3px;}
.zfree{background:var(--succ-10);border-radius:12px;padding:16px;margin-top:20px;}
.zfree b{font-size:14px;font-weight:700;color:#166534;display:block;}
.zfree span{font-size:13px;color:#15803D;}
@media(max-width:900px){.hdr-in,.content,.ft{padding-left:24px;padding-right:24px;}.nav{display:none;}.zwrap{flex-direction:column;}.zside{width:100%;position:static;}.pt h1{font-size:26px;}.ft-cols{flex-wrap:wrap;gap:24px;}}
/* ===== REFAR BRAND ===== */
.logo{display:flex;gap:10px;align-items:center;}
.logo .logo-mark{width:36px;height:36px;flex-shrink:0;display:block;}
.logo .logo-mark svg{width:100%;height:100%;display:block;}
.logo .logo-name{font-weight:800;font-size:20px;color:#1B2A4A;letter-spacing:.5px;line-height:1;}
.ft-logo{display:flex;gap:10px;align-items:center;}
.ft-logo .logo-mark{width:36px;height:36px;flex-shrink:0;display:block;}
.ft-logo .logo-mark svg{width:100%;height:100%;display:block;}
.ft-logo .logo-name{font-weight:800;font-size:22px;color:#1B2A4A;letter-spacing:.5px;}
a.hbtn.primary,a.hlink.primary,.hbtn.primary,.hlink.primary{background:#E24B4A!important;color:#fff!important;border-color:#E24B4A!important;text-decoration:none;display:inline-flex;align-items:center;}
a.hbtn.primary:hover,.hbtn.primary:hover,.hlink.primary:hover{background:#C63D3C!important;}
a.hbtn,a.hlink{text-decoration:none;}
</style>
<div class="content">
<div class="pt"><h1>Создать заявку на подбор</h1><p>Опишите параметры — наши риэлторы подберут варианты в течение 24 часов</p></div>
<div class="zwrap">
<div class="zform">
<div class="progress"><span class="pstep done"></span><span class="pstep on"></span><span class="pstep"></span><span class="pstep"></span><span class="pstep"></span></div>
<div class="pstep-label">Шаг 2 из 5 — параметры объекта</div>
<h2>Что вы ищете?</h2>
<div class="field"><div class="fl">Тип сделки</div><div class="chips"><span class="chip on">Купить</span><span class="chip">Снять</span><span class="chip">Посуточно</span></div></div>
<div class="field"><div class="fl">Тип недвижимости</div><div class="chips"><span class="chip on">Квартира</span><span class="chip">Дом</span><span class="chip">Новостройка</span><span class="chip">Коммерческая</span></div></div>
<div class="frow"><div class="field"><div class="fl">Город</div><div class="fselect">Ташкент ▾</div></div><div class="field"><div class="fl">Районы</div><div class="fselect">Чиланзар, Мирабад ▾</div></div></div>
<div class="field"><div class="fl">Количество комнат</div><div class="rooms"><span class="room">Студия</span><span class="room on">1</span><span class="room on">2</span><span class="room">3</span><span class="room">4</span><span class="room">5+</span></div></div>
<div class="frow"><div class="field"><div class="fl">Бюджет от</div><input class="finput" value="5 000 000 $"></div><div class="field"><div class="fl">до</div><input class="finput" value="12 000 000 $"></div></div>
<div class="form-btns"><button class="btn-back">← Назад</button><button class="btn-next">Продолжить →</button></div>
</div>
<div class="zside">
<h3>Что произойдёт дальше?</h3>
<div class="zstep"><span class="n">1</span><span class="t">Заполните параметры (5 минут)</span></div>
<div class="zstep"><span class="n">2</span><span class="t">3–5 риэлторов получат вашу заявку</span></div>
<div class="zstep"><span class="n">3</span><span class="t">Они подберут варианты под ваши требования</span></div>
<div class="zstep"><span class="n">4</span><span class="t">Вы выбираете лучшие и записываетесь на показ</span></div>
<div class="zfree"><b>✓ Услуга бесплатна для покупателей</b><span>Комиссию платит продавец, а не вы</span></div>
</div>
</div></div>
</div><script>document.querySelectorAll(".chips").forEach(function(g){g.querySelectorAll(".chip").forEach(function(c){c.addEventListener("click",function(){g.querySelectorAll(".chip").forEach(function(x){x.classList.remove("on");});c.classList.add("on");});});});
document.querySelectorAll(".room").forEach(function(c){c.addEventListener("click",function(){c.classList.toggle("on");});});</script>
{% endraw %}
