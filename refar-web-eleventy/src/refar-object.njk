<script>
// Sticky tabs — active holat scroll bo'yicha
var tabLinks=document.querySelectorAll(".tabnav a");
tabLinks.forEach(function(a){
  a.addEventListener("click",function(e){
    var id=a.getAttribute("href");
    if(id&&id.length>1&&document.querySelector(id)){
      e.preventDefault();
      document.querySelector(id).scrollIntoView({behavior:"smooth",block:"start"});
      tabLinks.forEach(function(x){x.classList.remove("on");});
      a.classList.add("on");
    }
  });
});
// Valyuta / media tab toggle
document.querySelectorAll(".cur-tabs").forEach(function(g){
  g.querySelectorAll("span").forEach(function(s){
    s.addEventListener("click",function(){g.querySelectorAll("span").forEach(function(x){x.classList.remove("on");});s.classList.add("on");});
  });
});
document.querySelectorAll(".media-tabs").forEach(function(g){
  g.querySelectorAll(".mtab:not(.spacer)").forEach(function(s){
    s.addEventListener("click",function(){
      if(s.textContent.indexOf("Все")>-1)return;
      g.querySelectorAll(".mtab").forEach(function(x){if(!x.classList.contains("spacer"))x.classList.remove("on");});s.classList.add("on");
    });
  });
});
document.querySelectorAll(".loc-ctrl").forEach(function(g){
  g.querySelectorAll("span").forEach(function(s){
    s.addEventListener("click",function(){g.querySelectorAll("span").forEach(function(x){x.classList.remove("on");});s.classList.add("on");});
  });
});
</script>
<script>
// REFAR — obyekt sahifasini ?id= bo'yicha Supabase'dan yuklash (id yo'q bo'lsa demo qoladi)
(function(){
  var id = new URLSearchParams(location.search).get('id');
  if(!id) return;
  function fmtPrice(l){
    var n = Number(l.price||0).toLocaleString('ru-RU');
    return l.currency==='UZS' ? n+' сум' : '$ '+n;
  }
  function setText(sel,val){ var el=document.querySelector(sel); if(el&&val!=null&&val!=='') el.textContent=val; }
  async function load(){
    if(!window.sb){ setTimeout(load,150); return; }
    try{
      var r = await window.sb.from('web_listings').select('*').eq('id',id).maybeSingle();
      var l = r.data;
      if(!l){ setText('.title-strip h1','Объявление не найдено'); return; }
      var title = l.title || ((l.rooms?l.rooms+'-комнатная ':'')+'квартира'+(l.area?', '+l.area+' м²':'')+(l.floor?', '+l.floor+(l.floor_total?' / '+l.floor_total:'')+' этаж':''));
      setText('.title-strip h1', title);
      document.title = title+' — REFAR';
      setText('.price-big', fmtPrice(l));
      if(l.area&&l.price){ var perM=Math.round(Number(l.price)/Number(l.area)); setText('.price-sum',(l.currency==='UZS'?perM.toLocaleString('ru-RU')+' сум':'$ '+perM.toLocaleString('ru-RU'))+' / м²'); }
      var addr=[l.region,l.district,l.address].filter(Boolean).join(', ');
      if(addr) setText('.ts-addr','📍 '+addr);
      if(l.description) setText('.desc-text', l.description);
      document.querySelectorAll('.ts-badges .tsb').forEach(function(b){ if(/REFAR ID/i.test(b.textContent)&&l.ref_code) b.textContent='REFAR ID · '+l.ref_code; });
      var imgs = Array.isArray(l.images)?l.images:[];
      if(imgs.length){
        var mp=document.querySelector('.main-photo');
        if(mp){ mp.style.backgroundImage='url('+imgs[0]+')'; mp.style.backgroundSize='cover'; mp.style.backgroundPosition='center'; }
        var th=document.querySelector('.thumbs');
        if(th){ th.innerHTML=imgs.slice(0,5).map(function(u){ return '<div class="thumb" style="background:url('+u+') center/cover"></div>'; }).join(''); }
        var cnt=document.querySelector('.mp-count'); if(cnt) cnt.textContent='📷 1 / '+imgs.length;
        document.querySelectorAll('.media-tabs .cnt').forEach(function(c){ c.textContent=imgs.length; });
      }
      document.querySelectorAll('#s-char .char-row').forEach(function(row){
        var k=row.querySelector('.k'), v=row.querySelector('.v'); if(!k||!v) return;
        var key=k.textContent.trim();
        if(/Площадь общая/.test(key)&&l.area) v.textContent=l.area+' м²';
        else if(/^Этаж/.test(key)&&l.floor) v.textContent=l.floor+(l.floor_total?' / '+l.floor_total:'');
        else if(/Год постройки/.test(key)&&l.year_built) v.textContent=l.year_built;
      });
    }catch(e){ console.warn('object load',e); }
  }
  document.addEventListener('DOMContentLoaded', load);
})();
</script>
