---
layout: base.njk
title: "3-комнатная квартира, 95 м² · REFAR"
activeNav: "catalog"
permalink: "/refar-object.html"
---
{% raw %}
<style>
:root{
  --brand:#1B2A4A; --brand-70:#122038; --brand-5:#EEF1F6; --brand-10:#DCE2EC; --brand-20:#C2CBDD;
  --g90:#0F172A; --g80:#1E293B; --g70:#334155; --g60:#475569; --g50:#64748B; --g40:#94A3B8;
  --g30:#CBD5E1; --g20:#E2E8F0; --g10:#F1F5F9; --g5:#F8FAFC; --white:#FFFFFF;
  --succ:#16A34A; --succ-10:#DCFCE7; --warn-10:#FEF3C7; --warn-60:#D97706; --purple-10:#F3E8FF;
  --red:#E24B4A; --red-10:#FEE2E2;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;background:var(--white);color:var(--g90);-webkit-font-smoothing:antialiased;font-size:14px;}
a{text-decoration:none;color:inherit;}
img{display:block;max-width:100%;}
.wrap{max-width:1440px;margin:0 auto;}

/* ─── HEADER ─── */
.hdr{background:var(--white);border-bottom:1px solid var(--g10);position:sticky;top:0;z-index:100;}
.hdr-in{display:flex;align-items:center;justify-content:space-between;padding:18px 80px;}
.hdr-left{display:flex;gap:40px;align-items:center;}
.logo{display:flex;gap:8px;align-items:center;}
.logo .mark{width:28px;height:28px;background:var(--brand);border-radius:8px;}
.logo .name{font-weight:800;font-size:19px;color:var(--g90);}
.nav{display:flex;gap:24px;align-items:center;}
.nav a{font-weight:500;font-size:14px;color:var(--g60);transition:color .15s;}
.nav a:hover{color:var(--brand);}
.hdr-right{display:flex;gap:14px;align-items:center;}
.hlink{font-weight:600;font-size:13px;color:var(--g80);padding:10px 16px;border-radius:8px;cursor:pointer;}
.hlink.ghost{background:var(--g5);border:1px solid var(--g20);}
.hlink.cmp{color:var(--brand);}
.hlink.primary{background:var(--brand);color:#fff;}
.hlink.primary:hover{background:var(--brand-70);}

/* ─── BREADCRUMBS ─── */
.crumbs{padding:18px 80px;display:flex;gap:9px;align-items:center;font-size:12px;color:var(--g50);flex-wrap:wrap;}
.crumbs .sep{color:var(--g30);}
.crumbs a:hover{color:var(--brand);}
.crumbs .cur{color:var(--g80);}

/* ─── LAYOUT ─── */
.px{padding-left:80px;padding-right:80px;}
.hero{display:flex;gap:24px;padding:24px 80px;align-items:flex-start;}

/* Gallery */
.gallery{flex:1;min-width:0;background:#fff;border:1px solid var(--g20);border-radius:16px;padding:16px;}
.media-tabs{display:flex;gap:8px;align-items:center;margin-bottom:14px;flex-wrap:wrap;}
.mtab{display:flex;gap:8px;align-items:center;padding:8px 14px;border-radius:8px;font-weight:600;font-size:13px;color:var(--g60);cursor:pointer;border:1px solid transparent;}
.mtab.on{background:var(--g90);color:#fff;}
.mtab .cnt{background:var(--g10);color:var(--g60);font-size:11px;padding:1px 7px;border-radius:20px;}
.mtab.on .cnt{background:rgba(255,255,255,.2);color:#fff;}
.mtab .pend{width:8px;height:8px;border-radius:50%;background:var(--warn-60);}
.mtab.spacer{flex:1;border:none;cursor:default;}
.media-area{display:flex;gap:12px;height:420px;}
.main-photo{width:560px;flex-shrink:0;background:linear-gradient(135deg,#dbe4fb,#c9d6f7);border-radius:12px;position:relative;overflow:hidden;}
.mp-top{position:absolute;top:14px;left:14px;right:14px;display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
.chip{background:rgba(255,255,255,.95);border-radius:6px;padding:5px 10px;font-size:11px;font-weight:500;color:var(--g70);display:flex;gap:6px;align-items:center;}
.chip .dot{width:6px;height:6px;border-radius:50%;}
.chip.round{margin-left:auto;width:32px;height:32px;justify-content:center;padding:0;border-radius:8px;font-size:15px;}
.mp-bot{position:absolute;bottom:14px;left:14px;right:14px;display:flex;align-items:center;gap:10px;}
.mp-count{background:rgba(15,23,42,.75);color:#fff;border-radius:6px;padding:6px 12px;font-size:13px;font-weight:600;display:flex;gap:8px;align-items:center;}
.mp-nav{margin-left:auto;display:flex;gap:8px;}
.mp-arrow{width:32px;height:32px;background:rgba(255,255,255,.95);border-radius:8px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:16px;color:var(--g70);}
.right-stack{flex:1;display:flex;flex-direction:column;gap:12px;}
.pend-card{flex:1;border-radius:12px;border:1px dashed var(--g30);background:var(--g5);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:16px;position:relative;}
.pend-badge{position:absolute;top:14px;left:50%;transform:translateX(-50%);display:flex;gap:6px;align-items:center;background:var(--warn-10);color:var(--warn-60);border-radius:20px;padding:4px 10px;font-size:11px;font-weight:600;}
.pend-badge .dot{width:6px;height:6px;border-radius:50%;background:var(--warn-60);}
.pend-play{width:42px;height:42px;border-radius:50%;background:var(--brand);color:#fff;display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:14px;}
.pend-card h4{font-size:14px;font-weight:600;color:var(--g80);margin-bottom:6px;}
.pend-card p{font-size:11px;color:var(--g50);line-height:1.4;margin-bottom:12px;}
.pend-notify{font-size:12px;font-weight:600;color:var(--brand);border:1px solid var(--brand-20);border-radius:8px;padding:6px 12px;cursor:pointer;}
.thumbs{display:flex;gap:10px;margin-top:12px;}
.thumb{flex:1;height:92px;border-radius:10px;background:linear-gradient(135deg,#e2e8f4,#d3dcef);cursor:pointer;}
.thumb.more{background:var(--g90);color:#fff;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;}

/* Sidebar */
.side{width:380px;flex-shrink:0;display:flex;flex-direction:column;gap:12px;position:sticky;top:100px;}
.price-card{background:#fff;border:1px solid var(--g20);border-radius:16px;padding:20px;box-shadow:0 4px 16px rgba(0,0,0,.05);}
.price-row{display:flex;align-items:center;gap:12px;}
.price-big{font-weight:800;font-size:32px;color:var(--g90);}
.price-drop{margin-left:auto;background:var(--succ-10);color:var(--succ);font-size:12px;font-weight:700;padding:5px 10px;border-radius:20px;}
.price-was{font-size:12px;color:var(--g50);margin-top:10px;}
.price-sum{font-size:13px;color:var(--g60);margin-top:6px;font-weight:500;}
.pc-div{height:1px;background:var(--g10);margin:16px 0;}
.mort-teaser{display:flex;align-items:center;gap:14px;}
.mort-ic{width:36px;height:32px;background:var(--brand-5);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;}
.mort-info{flex:1;}
.mort-info .m1{font-size:14px;font-weight:600;color:var(--g80);}
.mort-info .m2{font-size:12px;color:var(--g50);margin-top:2px;}
.mort-calc{font-size:13px;font-weight:600;color:var(--brand);cursor:pointer;}
.btn-lg{width:100%;padding:14px;border-radius:10px;border:none;font-family:inherit;font-weight:600;font-size:15px;cursor:pointer;transition:all .15s;}
.btn-blue{background:var(--brand);color:#fff;}
.btn-blue:hover{background:var(--brand-70);}
.btn-pair{display:flex;gap:8px;margin-top:10px;}
.btn-pair button{flex:1;padding:12px;border-radius:10px;border:1px solid var(--g20);background:#fff;font-family:inherit;font-weight:600;font-size:13px;color:var(--g70);cursor:pointer;transition:all .15s;}
.btn-pair button:hover{border-color:var(--brand);color:var(--brand);}
.btn-trio{display:flex;gap:8px;margin-top:10px;}
.btn-trio button{flex:1;padding:9px;border-radius:8px;border:none;background:transparent;font-family:inherit;font-weight:500;font-size:12px;color:var(--g60);cursor:pointer;}
.btn-trio button:hover{background:var(--g5);color:var(--brand);}
.agent-card{background:#fff;border:1px solid var(--g20);border-radius:16px;padding:18px;}
.agent-top{display:flex;gap:12px;align-items:center;}
.agent-av{width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,var(--brand),#3A5488);flex-shrink:0;}
.agent-name{font-size:15px;font-weight:600;color:var(--g90);}
.agent-meta{font-size:13px;color:var(--g50);margin-top:3px;display:flex;gap:6px;align-items:center;}
.agent-meta .star{color:var(--warn-60);font-weight:600;}
.agent-verif{margin-left:auto;background:var(--succ-10);color:var(--succ);font-size:11px;font-weight:600;padding:5px 10px;border-radius:20px;}
.agent-stats{display:flex;margin-top:16px;border-top:1px solid var(--g10);padding-top:14px;}
.agent-stat{flex:1;}
.agent-stat b{font-size:16px;font-weight:700;color:var(--g90);}
.agent-stat span{font-size:12px;color:var(--g50);display:block;margin-top:2px;}

/* ─── TITLE STRIP ─── */
.title-strip{padding:28px 80px;display:flex;justify-content:space-between;align-items:flex-start;gap:20px;border-top:1px solid var(--g10);}
.ts-badges{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;}
.tsb{background:var(--g5);border:1px solid var(--g20);border-radius:6px;padding:5px 10px;font-size:11px;font-weight:500;color:var(--g60);display:flex;gap:6px;align-items:center;}
.tsb .dot{width:6px;height:6px;border-radius:50%;background:var(--succ);}
.tsb.succ{background:var(--succ-10);color:var(--succ);border-color:transparent;}
.tsb.brand{background:var(--brand-5);color:var(--brand-70);border-color:transparent;}
.title-strip h1{font-size:28px;font-weight:700;color:var(--g90);line-height:1.2;}
.ts-addr{font-size:14px;color:var(--g60);margin-top:12px;display:flex;gap:6px;align-items:center;}
.ts-stats{display:flex;gap:24px;margin-top:16px;flex-wrap:wrap;}
.ts-stat{display:flex;gap:8px;align-items:center;}
.ts-stat .ico{font-size:13px;opacity:.7;}
.ts-stat b{font-size:14px;font-weight:600;color:var(--g80);}
.ts-stat span{font-size:12px;color:var(--g50);display:block;}
.ts-actions{display:flex;gap:8px;flex-shrink:0;}
.ts-act{border:1px solid var(--g20);border-radius:8px;padding:9px 14px;font-size:13px;font-weight:500;color:var(--g60);cursor:pointer;white-space:nowrap;}
.ts-act:hover{border-color:var(--brand);color:var(--brand);}

/* ─── STICKY TABS ─── */
.tabnav{position:sticky;top:73px;z-index:90;background:#fff;border-top:1px solid var(--g10);border-bottom:1px solid var(--g10);padding:0 80px;display:flex;gap:0;overflow-x:auto;}
.tabnav a{padding:18px;font-size:14px;font-weight:500;color:var(--g60);white-space:nowrap;border-bottom:2px solid transparent;display:flex;gap:6px;align-items:center;}
.tabnav a.on,.tabnav a:hover{color:var(--brand);border-bottom-color:var(--brand);}
.tabnav a .dot{width:6px;height:6px;border-radius:50%;background:var(--succ);}

/* ─── MAIN CONTENT ─── */
.main{display:flex;gap:24px;padding:28px 80px;align-items:flex-start;}
.article{flex:1;min-width:0;display:flex;flex-direction:column;gap:16px;}
.sec-card{background:#fff;border:1px solid var(--g20);border-radius:16px;padding:24px;}
.sec-head{display:flex;align-items:center;gap:14px;margin-bottom:20px;}
.sec-head h2{font-size:19px;font-weight:700;color:var(--g90);white-space:nowrap;}
.sec-head .line{flex:1;height:1px;background:var(--g10);}
.sec-head .tag{background:var(--g5);border:1px solid var(--g20);border-radius:6px;padding:5px 10px;font-size:11px;font-weight:500;color:var(--g60);white-space:nowrap;}
.sec-head .tag.dot::before{content:"";display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--succ);margin-right:6px;vertical-align:middle;}

/* Right anchors */
.anchors{width:380px;flex-shrink:0;position:sticky;top:145px;background:#fff;border:1px solid var(--g20);border-radius:16px;padding:18px;}
.anchors .at{font-size:13px;font-weight:600;color:var(--g80);margin-bottom:14px;}
.anchors a{display:flex;gap:10px;align-items:center;font-size:14px;color:var(--g60);padding:6px 0;}
.anchors a:hover{color:var(--brand);}
.anchors a .m{color:var(--g30);}
.anchors .ndiv{height:1px;background:var(--g10);margin:14px 0;}
.anchors .note{font-size:13px;color:var(--g60);line-height:1.5;}

/* Locations */
.loc-map{height:360px;border-radius:12px;background:linear-gradient(135deg,#eef2f8,#e2e8f4);position:relative;overflow:hidden;margin-bottom:24px;}
.loc-map .pin{position:absolute;width:46px;height:46px;border-radius:50%;background:rgba(27,42,74,.15);display:flex;align-items:center;justify-content:center;}
.loc-map .pin::after{content:"";width:14px;height:14px;border-radius:50%;background:var(--brand);border:3px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,.2);}
.loc-poi{position:absolute;background:#fff;border-radius:8px;width:32px;height:28px;display:flex;align-items:center;justify-content:center;font-size:14px;box-shadow:0 2px 8px rgba(0,0,0,.12);}
.loc-ctrl{position:absolute;bottom:16px;left:16px;display:flex;gap:6px;background:#fff;border-radius:8px;padding:6px;box-shadow:0 2px 8px rgba(0,0,0,.1);}
.loc-ctrl span{padding:5px 10px;font-size:12px;font-weight:500;color:var(--g60);border-radius:6px;cursor:pointer;}
.loc-ctrl span.on{background:var(--brand);color:#fff;}
.subhead{font-size:15px;font-weight:600;color:var(--g80);margin-bottom:16px;display:flex;align-items:center;gap:12px;}
.subhead .line{flex:1;height:1px;background:var(--g10);}
.subhead .tag{font-size:11px;font-weight:500;color:var(--g50);white-space:nowrap;}
.poi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px;}
.poi-card{border:1px solid var(--g20);border-radius:10px;padding:14px;}
.poi-top{display:flex;gap:10px;align-items:flex-start;}
.poi-ic{font-size:18px;}
.poi-name{font-size:14px;font-weight:600;color:var(--g90);}
.poi-desc{font-size:12px;color:var(--g50);margin-top:2px;}
.poi-dist{display:flex;gap:12px;margin-top:12px;font-size:13px;color:var(--g60);}
.poi-mini{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;}
.poi-min{display:flex;gap:6px;align-items:center;font-size:13px;color:var(--g60);padding:6px 0;}
.poi-min b{color:var(--g80);font-weight:500;}
.poi-min .mdist{margin-left:auto;color:var(--g50);font-size:12px;}

/* Description */
.desc-text{font-size:14px;line-height:1.7;color:var(--g60);}
.show-more{margin-top:16px;font-size:14px;font-weight:600;color:var(--brand);cursor:pointer;}

/* Price history */
.ph-lead{font-size:14px;line-height:1.6;color:var(--g60);margin-bottom:20px;}
.ph-grid{display:flex;gap:20px;}
.ph-chart-box{width:360px;flex-shrink:0;border:1px solid var(--g20);border-radius:12px;padding:18px;}
.ph-cur{display:flex;align-items:flex-end;gap:20px;margin-bottom:16px;}
.ph-cur .big{font-size:28px;font-weight:800;color:var(--g90);}
.ph-cur .lbl{font-size:13px;color:var(--g50);}
.ph-cur .old{font-size:16px;font-weight:600;color:var(--g40);text-decoration:line-through;}
.ph-chart{height:120px;position:relative;margin:10px 0;}
.ph-xaxis{display:flex;justify-content:space-between;font-size:11px;color:var(--g40);margin-top:8px;}
.ph-events{flex:1;display:flex;flex-direction:column;gap:10px;}
.ph-ev{display:flex;gap:16px;align-items:center;border:1px solid var(--g20);border-radius:10px;padding:14px;}
.ph-ev .date{width:60px;flex-shrink:0;}
.ph-ev .date b{font-size:15px;font-weight:600;color:var(--g80);display:block;}
.ph-ev .date span{font-size:12px;color:var(--g50);}
.ph-ev .chg{flex:1;}
.ph-ev .chg .prices{font-size:14px;color:var(--g80);}
.ph-ev .chg .prices .to{font-weight:600;}
.ph-ev .chg .sub{font-size:13px;color:var(--succ);margin-top:2px;}
.ph-ev .last{background:var(--brand-5);color:var(--brand-70);font-size:11px;font-weight:600;padding:4px 10px;border-radius:20px;}
.ph-subscribe{display:flex;gap:14px;align-items:center;border:1px solid var(--g20);border-radius:12px;padding:16px;margin-top:20px;background:var(--g5);}
.ph-subscribe .txt{flex:1;}
.ph-subscribe .txt b{font-size:14px;font-weight:600;color:var(--g80);display:block;}
.ph-subscribe .txt span{font-size:13px;color:var(--g50);}
.ph-subscribe button{background:var(--brand);color:#fff;border:none;border-radius:8px;padding:10px 16px;font-family:inherit;font-weight:600;font-size:13px;cursor:pointer;}

/* Characteristics */
.char-grid{display:grid;grid-template-columns:1fr 1fr;gap:0 48px;}
.char-row{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid var(--g10);}
.char-row .k{font-size:14px;color:var(--g60);white-space:nowrap;}
.char-row .line{flex:1;height:1px;background:var(--g10);min-width:10px;}
.char-row .v{font-size:14px;font-weight:600;color:var(--g80);white-space:nowrap;}
.char-row .v .pill{background:var(--brand-5);color:var(--brand-70);font-size:11px;font-weight:600;padding:3px 8px;border-radius:20px;margin-left:8px;}
.char-row .v .pill.succ{background:var(--succ-10);color:var(--succ);}

/* Amenities */
.amen-group+.amen-group{margin-top:24px;}
.amen-title{font-size:15px;font-weight:600;color:var(--g80);margin-bottom:16px;}
.amen-list{display:flex;flex-wrap:wrap;gap:10px 24px;}
.amen{display:flex;gap:10px;align-items:center;font-size:14px;color:var(--g70);}
.amen .ic{font-size:14px;}

/* Mortgage calculator */
.mort-head{display:flex;gap:12px;align-items:flex-start;margin-bottom:20px;}
.mort-head .ic{width:38px;height:34px;background:var(--brand-5);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.mort-head h2{font-size:19px;font-weight:700;color:var(--g90);}
.mort-head .sub{font-size:13px;color:var(--g50);margin-top:4px;}
.mort-head .acc{margin-left:auto;background:var(--succ-10);color:var(--succ);font-size:11px;font-weight:600;padding:6px 12px;border-radius:20px;display:flex;gap:6px;align-items:center;white-space:nowrap;}
.mort-head .acc .dot{width:6px;height:6px;border-radius:50%;background:var(--succ);}
.mort-body{display:flex;gap:24px;}
.mort-left{flex:1;min-width:0;display:flex;flex-direction:column;gap:22px;}
.slider-row .st{display:flex;justify-content:space-between;font-size:13px;color:var(--g60);margin-bottom:8px;}
.slider-row .st .hint{font-size:12px;color:var(--g40);}
.slider-val{display:flex;align-items:center;border:1px solid var(--g20);border-radius:10px;padding:12px 14px;margin-bottom:10px;}
.slider-val b{font-size:16px;font-weight:700;color:var(--g90);}
.slider-val .unit{margin-left:auto;font-size:14px;color:var(--g50);font-weight:500;}
.track{height:6px;background:var(--g10);border-radius:3px;position:relative;}
.track .fill{height:100%;background:var(--brand);border-radius:3px;}
.track .fill::after{content:"";position:absolute;top:50%;right:-2px;transform:translate(0,-50%);width:16px;height:16px;background:#fff;border:3px solid var(--brand);border-radius:50%;box-shadow:0 2px 4px rgba(0,0,0,.15);}
.cur-tabs{display:flex;gap:8px;background:var(--g10);border-radius:10px;padding:4px;}
.cur-tabs span{flex:1;text-align:center;padding:9px;border-radius:8px;font-size:14px;font-weight:600;color:var(--g60);cursor:pointer;}
.cur-tabs span.on{background:#fff;color:var(--g90);box-shadow:0 1px 3px rgba(0,0,0,.1);}
.mort-btns{display:flex;gap:12px;}
.mort-btns .calc{flex:1;background:var(--brand);color:#fff;border:none;border-radius:10px;padding:14px;font-family:inherit;font-weight:600;font-size:14px;cursor:pointer;}
.mort-btns .reset{background:var(--g5);border:1px solid var(--g20);border-radius:10px;padding:14px 24px;font-family:inherit;font-weight:600;font-size:14px;color:var(--g60);cursor:pointer;}
.mort-result{width:380px;flex-shrink:0;background:var(--g90);border-radius:16px;padding:22px;color:#fff;}
.mr-head{display:flex;align-items:center;gap:12px;margin-bottom:18px;}
.mr-head .lbl{font-size:14px;color:var(--g30);}
.mr-head .line{flex:1;height:1px;background:rgba(255,255,255,.1);}
.mr-head .tag{background:rgba(255,255,255,.1);border-radius:20px;padding:4px 10px;font-size:11px;font-weight:600;}
.mr-big{font-size:42px;font-weight:800;margin-bottom:6px;}
.mr-sum{font-size:14px;color:var(--g40);margin-bottom:18px;}
