---
layout: base.njk
title: "Результат оценки · REFAR"
activeNav: "baholash"
permalink: "/refar-bahol-natija.html"
---
{% raw %}
<style>
:root{--brand:#1B2A4A;--brand-70:#122038;--brand-5:#EEF1F6;--brand-10:#DCE2EC;--brand-20:#C2CBDD;--g90:#0F172A;--g80:#1E293B;--g70:#334155;--g60:#475569;--g50:#64748B;--g40:#94A3B8;--g30:#CBD5E1;--g20:#E2E8F0;--g10:#F1F5F9;--g5:#F8FAFC;--succ:#16A34A;--succ-10:#DCFCE7;}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;background:var(--g5);color:var(--g90);font-size:14px;-webkit-font-smoothing:antialiased;}
a{text-decoration:none;color:inherit;}
.wrap{max-width:1440px;margin:0 auto;}
.hdr{background:#fff;border-bottom:1px solid var(--g10);position:sticky;top:0;z-index:100;}
.hdr-in{display:flex;align-items:center;justify-content:space-between;padding:16px 80px;}
.hdr-left{display:flex;gap:40px;align-items:center;}
.logo{display:flex;gap:10px;align-items:center;}
.logo .mark{width:32px;height:32px;background:var(--brand);border-radius:8px;}
.logo .name{font-weight:800;font-size:20px;}
.nav{display:flex;gap:28px;}
.nav a{font-weight:500;font-size:14px;color:var(--g60);}
.nav a:hover,.nav a.on{color:var(--brand);}
.hdr-right{display:flex;gap:16px;align-items:center;}
.hbtn{font-weight:600;font-size:13px;padding:10px 16px;border-radius:8px;cursor:pointer;}
.hbtn.ghost{background:var(--g5);border:1px solid var(--g20);}
.hbtn.primary{background:var(--brand);color:#fff;}
.content{padding:40px 80px 0;max-width:1100px;margin:0 auto;}
.result-hero{background:linear-gradient(135deg,var(--brand),var(--brand-70));border-radius:20px;padding:36px;color:#fff;text-align:center;}
.rh-badge{display:inline-flex;gap:8px;align-items:center;background:rgba(255,255,255,.2);border-radius:20px;padding:6px 14px;font-size:13px;font-weight:600;margin-bottom:16px;}
.result-hero h1{font-size:22px;font-weight:600;opacity:.9;}
.rh-addr{font-size:14px;opacity:.8;margin-top:8px;}
.rh-price-label{font-size:14px;opacity:.85;margin-top:24px;}
.rh-price{font-size:52px;font-weight:800;margin-top:6px;}
.rh-permet{font-size:15px;opacity:.85;margin-top:6px;}
.rh-range{display:flex;justify-content:center;gap:60px;margin-top:24px;padding-top:24px;border-top:1px solid rgba(255,255,255,.2);}
.rh-r span{font-size:13px;opacity:.75;display:block;}
.rh-r b{font-size:20px;font-weight:700;}
.card{background:#fff;border:1px solid var(--g20);border-radius:16px;padding:28px;margin-top:24px;}
.card h2{font-size:20px;font-weight:700;color:var(--g90);}
.card .sub{font-size:14px;color:var(--g50);margin-top:4px;margin-bottom:20px;}
.trend-badge{display:inline-block;background:var(--succ-10);color:var(--succ);font-size:14px;font-weight:700;padding:6px 14px;border-radius:20px;margin-bottom:16px;}
.chart{height:200px;position:relative;margin:16px 0;}
.chart-x{display:flex;justify-content:space-between;font-size:11px;color:var(--g40);margin-top:8px;}
.factors{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.factor{display:flex;gap:14px;align-items:flex-start;border:1px solid var(--g10);border-radius:12px;padding:16px;}
.factor .ic{width:36px;height:36px;background:var(--brand-5);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.factor .ft b{font-size:14px;font-weight:600;color:var(--g80);display:block;}
.factor .ft span{font-size:13px;color:var(--g50);margin-top:3px;display:block;line-height:1.4;}
.comps{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
.comp{border:1px solid var(--g20);border-radius:12px;overflow:hidden;}
.comp-photo{height:120px;background:linear-gradient(135deg,#dbe4fb,#c9d6f7);position:relative;}
.comp-sim{position:absolute;top:10px;right:10px;background:var(--succ);color:#fff;font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;}
.comp-body{padding:14px;}
.comp-price{font-size:18px;font-weight:800;color:var(--g90);}
.comp-addr{font-size:13px;color:var(--g60);margin-top:6px;}
.comp-spec{font-size:12px;color:var(--g50);margin-top:6px;}
.cta{background:linear-gradient(135deg,#EDF0F6,#F2F1F7);border:1px solid var(--brand-20);border-radius:16px;padding:28px;margin-top:24px;text-align:center;}
.cta h2{font-size:22px;font-weight:700;color:var(--g90);}
.cta p{font-size:14px;color:var(--g60);margin-top:8px;}
.cta-btns{display:flex;gap:12px;justify-content:center;margin-top:20px;}
.cta-btns .primary{background:var(--brand);color:#fff;border:none;border-radius:10px;padding:13px 28px;font-family:inherit;font-weight:600;font-size:14px;cursor:pointer;}
.cta-btns .ghost{background:#fff;border:1px solid var(--g20);color:var(--g70);border-radius:10px;padding:13px 28px;font-family:inherit;font-weight:600;font-size:14px;cursor:pointer;}
.ft{background:#fff;border-top:1px solid var(--g10);padding:48px 80px 32px;margin-top:48px;}
.ft-cols{display:flex;justify-content:space-between;max-width:1280px;margin:0 auto;}
.ft-col{display:flex;flex-direction:column;gap:12px;}
.ft-col .t{font-weight:700;font-size:13px;color:var(--g80);}
.ft-col a{font-size:12px;color:var(--g60);}
.ft-col a:hover{color:var(--brand);}
.ft-line{height:1px;background:var(--g10);margin:32px auto 20px;max-width:1280px;}
.ft-cp{font-size:12px;color:var(--g50);max-width:1280px;margin:0 auto;}
@media(max-width:900px){.hdr-in,.content,.ft{padding-left:24px;padding-right:24px;}.nav{display:none;}.factors,.comps{grid-template-columns:1fr;}.rh-price{font-size:38px;}.rh-range{gap:30px;}.cta-btns{flex-direction:column;}.ft-cols{flex-wrap:wrap;gap:24px;}}

/* ===== REFAR BRAND ===== */
.logo{display:flex;gap:10px;align-items:center;}
.logo .logo-mark{width:36px;height:36px;flex-shrink:0;display:block;}
.logo .logo-mark svg{width:100%;height:100%;display:block;}
.logo .logo-name{font-weight:800;font-size:20px;color:#1B2A4A;letter-spacing:.5px;line-height:1;}
.ft-logo{display:flex;gap:10px;align-items:center;}
.ft-logo .logo-mark{width:36px;height:36px;flex-shrink:0;display:block;}
.ft-logo .logo-mark svg{width:100%;height:100%;display:block;}
.ft-logo .logo-name{font-weight:800;font-size:22px;color:#1B2A4A;letter-spacing:.5px;}
a.hbtn.primary,a.hlink.primary,.hbtn.primary,.hlink.primary{background:#E24B4A!important;color:#fff!important;border-color:#E24B4A!important;text-decoration:none;display:inline-flex;align-items:center;}
a.hbtn.primary:hover,.hbtn.primary:hover,.hlink.primary:hover{background:#C63D3C!important;}
a.hbtn,a.hlink{text-decoration:none;}
</style>
