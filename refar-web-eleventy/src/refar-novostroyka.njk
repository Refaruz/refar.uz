.zk-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:32px;}
.zk{background:#fff;border:1px solid var(--g20);border-radius:16px;overflow:hidden;cursor:pointer;transition:all .15s;}
.zk:hover{box-shadow:0 12px 30px rgba(0,0,0,.1);transform:translateY(-3px);}
.zk-photo{height:200px;position:relative;}
