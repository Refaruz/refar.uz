.zk-install{display:flex;align-items:center;gap:8px;margin-top:14px;background:var(--succ-10);border-radius:8px;padding:10px 12px;}
.zk-install .b{background:var(--succ);color:#fff;font-size:11px;font-weight:600;padding:3px 8px;border-radius:6px;}
.zk-install span{font-size:12px;color:#166534;}
.zk-btn{width:100%;margin-top:14px;background:var(--brand);color:#fff;border:none;border-radius:10px;padding:12px;font-family:inherit;font-weight:600;font-size:14px;cursor:pointer;}
.more{text-align:center;margin:40px 0;}
.more button{background:#fff;border:1px solid var(--brand);color:var(--brand);border-radius:10px;padding:14px 40px;font-family:inherit;font-weight:600;font-size:14px;cursor:pointer;}
.ft{background:#fff;border-top:1px solid var(--g10);padding:48px 80px 32px;margin-top:40px;}
.ft-cols{display:flex;justify-content:space-between;}
.ft-col{display:flex;flex-direction:column;gap:12px;}
.ft-col .t{font-weight:700;font-size:13px;color:var(--g80);}
.ft-col a{font-size:12px;color:var(--g60);}
.ft-col a:hover{color:var(--brand);}
.ft-line{height:1px;background:var(--g10);margin:32px 0 20px;}
.ft-cp{font-size:12px;color:var(--g50);}
@media(max-width:1100px){.hdr-in,.content,.ft{padding-left:32px;padding-right:32px;}.nav{display:none;}.zk-grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:700px){.zk-grid{grid-template-columns:1fr;}.hero h1{font-size:28px;}.stats{flex-wrap:wrap;gap:20px;}.ft-cols{flex-wrap:wrap;gap:24px;}}

